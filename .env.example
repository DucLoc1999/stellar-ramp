NODE_ENV=development
PORT=3000
HOST=0.0.0.0
DOMAIN=localhost
LOG_LEVEL=info

# SePay API key — Bearer token (spsk_...) used for both PG and userapi.sepay.vn/v2
# Bank account XID is fetched automatically from /v2/bank-accounts on first use
SEPAY_ENV=sandbox  # not need
SEPAY_ID=SP-TEST-ND29BA23  # not need
SEPAY_KEY=spsk_test_LuMwuVy6dxXW35CXo8qhdMrhKr9Lq4qX  # not need
SEPAY_VA_NUMBER=  # Virtual Account or real Account number 
SEPAY_VA_HOLDER=  # Account holder name
SEPAY_BANK_NAME=  # Bank name
SEPAY_BANK_SHORT=  # Bank short name

# SePay userapi v2 Bearer token — get from SePay dashboard → API Keys
# If different from SEPAY_KEY, set this. Otherwise SEPAY_KEY is used as fallback.
SEPAY_API_KEY=

# SePay Webhook API Key (set in SePay dashboard under Webhooks → Authentication)
SEPAY_WEBHOOK_API_KEY=

# db
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=orbitlabs
DB_SSL=false

# Schema (optional, default: payment_svc)
DB_SCHEMA=payment_svc

# Redis (required for order reservation)
REDIS_URL=redis://localhost:6379
RESERVATION_BUFFER_USDC=1
RESERVATION_BUFFER_XLM=1
RESERVATION_SWEEP_INTERVAL_MS=5000
RESERVATION_WALLET_SYNC_INTERVAL_MS=15000
RESERVATION_RECONCILE_INTERVAL_MS=60000

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=payment_svc
KAFKA_DISBURSE_TOPIC=disburse_crypto
KAFKA_ORDER_PAID_TOPIC=order_paid
KAFKA_TOKEN_IN_TOPIC=stellar_token_in

# Stellar
STELLAR_NETWORK=testnet
WORKER_URL=http://localhost:8787
WORKER_AUTH_TOKEN=
STELLAR_HOT_WALLET_NAME=stellar_hot_wallet
STELLAR_HOT_WALLET_ENCRYPTION_KEY=  # openssl rand -base64 32
# Asset code to disburse (USDC on mainnet, USDC on testnet)
ASSET_CODE=USDC
# Token issuer address (USDC: GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN on mainnet)
TOKEN_ADDRESS=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# Stellar wallet
# If not set, falls back to system_wallets DB table
WALLET_ADDRESS=
STELLAR_LISTENER_FALLBACK_URL=http://localhost:3000/api/webhooks/stellar-incoming
STELLAR_LISTENER_FALLBACK_AUTH_TOKEN=  # openssl rand -base64 32

# Admin auth (for /login, PATCH /config, GET /stats)
ADMIN_JWT_SECRET=change-me
# Optional (default 43200 = 12h)
ADMIN_JWT_TTL_SEC=43200
# Optional bootstrap admin (created on startup if missing)
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me-too
CMS_CREATE_ADMIN_KEY=

# Partner API key (client → service auth)
PARTNER_APP_KEY=

# Callback webhook settings
CALLBACK_TIMEOUT_MS=8000
CALLBACK_RETRY_COUNT=3
CALLBACK_RETRY_DELAY_MS=5000

# Callback signature secret (shared with client for HMAC verification)
CALLBACK_SIGNATURE_SECRET=

# Chain webhook secret (provider → service auth)
CHAIN_WEBHOOK_SECRET=

# Minimum fee in VND (default: 5000)
MIN_FEE_VND=5000

# Order expiry time in minutes (default: 5)
ORDER_EXPIRY_MINUTES=5

# CoinGecko API key (for XLM price)
COINGECKO_API_KEY=
PRICE_SOURCE=coingecko
DB_PATH=./p2p_prices.db

# Payout (PayOS — VND bank transfer)
PAYOUT_MODE=stub
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# Landing page
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

