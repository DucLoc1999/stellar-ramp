# Environment variables for payment service
# -------------------------------------------------
# General server settings
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
DOMAIN=localhost
LOG_LEVEL=info

# SePay configuration
SEPAY_ENV=sandbox               # sandbox or production
SEPAY_API_KEY=                  # SePay API key (Bearer token) for merchant API
SEPAY_WEBHOOK_API_KEY=          # SePay webhook API key (Apikey header)
SEPAY_VA_NUMBER=                # Virtual Account number (optional)
SEPAY_VA_HOLDER=                # Account holder name (optional)
SEPAY_BANK_NAME=                # Bank name (optional)
SEPAY_BANK_SHORT=               # Bank short name (optional)
SEPAY_CHECKSUM_KEY=             # Checksum key for SePay requests

# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=orbitlabs
DB_SSL=false                    # Enable SSL for DB connection (default: false)
DB_SCHEMA=payment_svc           # Schema name (default: payment_svc)
DB_PATH=./data/p2p_prices.db         # Path to price DB file (default: ./p2p_prices.db)

# Redis configuration (required for reservation)
REDIS_URL=redis://localhost:6379
RESERVATION_BUFFER_USDC=1       # Reserve buffer for USDC (micro-units)
RESERVATION_BUFFER_XLM=1        # Reserve buffer for XLM (micro-units)
RESERVATION_SWEEP_INTERVAL_MS=5000   # How often to sweep expired reservations
RESERVATION_WALLET_SYNC_INTERVAL_MS=15000 # Sync wallet balances interval
RESERVATION_RECONCILE_INTERVAL_MS=60000 # Reconcile reservations interval

# Kafka configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=payment_svc
KAFKA_DISBURSE_TOPIC=disburse_crypto
KAFKA_ORDER_PAID_TOPIC=order_paid
KAFKA_TOKEN_IN_TOPIC=stellar_token_in

# Stellar configuration
STELLAR_NETWORK=testnet         # testnet or public
STELLAR_HOT_WALLET_NAME=stellar_hot_wallet
STELLAR_HOT_WALLET_ENCRYPTION_KEY=   # 32+ char key for AES-256-GCM
STELLAR_LISTENER_FALLBACK_URL=http://localhost:3000/api/webhooks/stellar-incoming
STELLAR_LISTENER_FALLBACK_AUTH_TOKEN=

# Admin configuration
ADMIN_JWT_SECRET=change-me      # JWT secret for admin routes (default: change-me)
ADMIN_JWT_TTL_SEC=43200         # JWT TTL in seconds (default: 43200 = 12h)
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me-too
CMS_CREATE_ADMIN_KEY=           # Partner API key (client → service auth) (optional)

# Callback webhook configuration
CALLBACK_TIMEOUT_MS=8000        # HTTP timeout for callback (default: 8000)
CALLBACK_RETRY_COUNT=3          # Number of retry attempts (default: 3)
CALLBACK_RETRY_DELAY_MS=5000    # Delay between retries (default: 5000)
CALLBACK_SIGNATURE_SECRET=      # HMAC secret for callback signing (shared with client)

# Chain webhook configuration
CHAIN_WEBHOOK_SECRET=           # HMAC secret for chain webhook (provider → service auth)

# Fees and pricing
MIN_FEE_VND=5000                # Minimum fee in VND (default: 5000)
ORDER_EXPIRY_MINUTES=5          # Order expiry time in minutes (default: 5)
PRICE_SOURCE=coingecko          # Price source (coingecko or other) (default: coingecko)

# Payout (PayOS) configuration
PAYOUT_MODE=stub                # stub or real (default: stub)
PAYOS_CLIENT_ID=                # PayOS client ID
PAYOS_API_KEY=                  # PayOS API key
PAYOS_CHECKSUM_KEY=             # PayOS checksum key
PAYOS_VA_NUMBER=                # PayOS virtual account number (optional)
PAYOS_VA_HOLDER=                # PayOS account holder name (optional)
PAYOS_BANK_NAME=                # PayOS bank name (optional)
PAYOS_BANK_SHORT=               # PayOS bank short name (optional)