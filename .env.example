NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# SePay PG credentials (merchant dashboard)
SEPAY_ENV=sandbox
SEPAY_ID=SP-TEST-...
SEPAY_KEY=spsk_test_...

# SePay Webhook API Key (set in SePay dashboard under Webhooks → Authentication)
SEPAY_WEBHOOK_API_KEY=

# db
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=orbitlabs

# Schema (optional, default: payment_svc)
DB_SCHEMA=payment_svc

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=payment_svc
KAFKA_DISBURSE_TOPIC=disburse_crypto
KAFKA_ORDER_PAID_TOPIC=order_paid

# Stellar
STELLAR_NETWORK=testnet
STELLAR_HOT_WALLET_NAME=stellar_hot_wallet
STELLAR_HOT_WALLET_ENCRYPTION_KEY=

# Admin auth (for /login, PATCH /config, GET /stats)
ADMIN_JWT_SECRET=change-me
# Optional (default 43200 = 12h)
ADMIN_JWT_TTL_SEC=43200
# Optional bootstrap admin (created on startup if missing)
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me-too
