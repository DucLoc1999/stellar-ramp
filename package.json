{
  "name": "payment-svc",
  "version": "1.0.0",
  "type": "commonjs",
  "description": "Price engine, fee management and SePay integration",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker:disburse": "tsx src/workers/disburseWorker.ts",
    "worker:vnd-payout": "tsx src/workers/vndPayoutWorker.ts",
    "worker:stellar-listen": "tsx stellar-listener/src/index.ts",
    "migrate": "tsx node_modules/.bin/knex migrate:latest --knexfile src/knexfile.ts",
    "migrate:prod": "node node_modules/.bin/knex migrate:latest --knexfile dist/knexfile.js",
    "migrate:rollback": "tsx node_modules/.bin/knex migrate:rollback --knexfile src/knexfile.ts",
    "wallet:add": "tsx scripts/add-wallet.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@payos/node": "^2.0.5",
    "@stellar/stellar-sdk": "^15.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "kafkajs": "^2.2.4",
    "knex": "^3.1.0",
    "pg": "^8.13.0",
    "sepay-pg-node": "^1.0.0",
    "stellar-sdk": "^13.3.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "js-yaml": "^4.1.0",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
