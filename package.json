{
  "name": "payment-svc",
  "version": "1.0.0",
  "type": "commonjs",
  "description": "Price engine, fee management and SePay integration",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "tsx node_modules/.bin/knex migrate:latest --knexfile src/knexfile.ts",
    "migrate:prod": "node node_modules/.bin/knex migrate:latest --knexfile dist/knexfile.js",
    "migrate:rollback": "tsx node_modules/.bin/knex migrate:rollback --knexfile src/knexfile.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.2.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.29.1",
    "knex": "^3.1.0",
    "pg": "^8.13.0",
    "sepay-pg-node": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  }
}
